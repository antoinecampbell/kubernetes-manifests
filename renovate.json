{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "enabledManagers": ["kubernetes", "helmv3", "kustomize"],
  "prCreation": "immediate",
  "packageRules": [
    {
      "matchDatasources": ["helm"],
      "pinDigests": false
    }
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/k8s/.+\\.yaml$/"
    ]
  }
}
